<?xml version="1.0" encoding="utf-8"?>
<!--
  VitalRoute — App icon foreground
  108×108dp canvas with 18dp safe-zone padding on each side (active area: 18–90)
  Design: green route curve with start dot + red SOS pin at end + small warning triangle
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Route track (thick dark-green glow) ── -->
    <path
        android:pathData="M22,78 C30,60 38,68 46,54 C54,40 62,28 78,36 C86,40 90,48 94,38"
        android:strokeColor="#1B5E35"
        android:strokeWidth="9"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>

    <!-- ── Route track (bright green line) ── -->
    <path
        android:pathData="M22,78 C30,60 38,68 46,54 C54,40 62,28 78,36 C86,40 90,48 94,38"
        android:strokeColor="#22C55E"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>

    <!-- ── Start dot (filled green circle) ── -->
    <path
        android:pathData="M22,78m-5.5,0a5.5,5.5 0,1 1,11 0a5.5,5.5 0,1 1,-11 0"
        android:fillColor="#22C55E"/>
    <!-- Start dot inner -->
    <path
        android:pathData="M22,78m-2.5,0a2.5,2.5 0,1 1,5 0a2.5,2.5 0,1 1,-5 0"
        android:fillColor="#111820"/>

    <!-- ── SOS pin at end of route ── -->
    <!-- Pin body (teardrop): circle at top, pointed bottom -->
    <path
        android:pathData="M94,38m-7,0a7,7 0,1 1,14 0a7,7 0,1 1,-14 0"
        android:fillColor="#EF4444"/>
    <path
        android:pathData="M88,43 L94,52 L100,43"
        android:fillColor="#EF4444"/>
    <!-- Pin highlight dot -->
    <path
        android:pathData="M94,38m-2.5,0a2.5,2.5 0,1 1,5 0a2.5,2.5 0,1 1,-5 0"
        android:fillColor="#FFFFFF"/>

    <!-- ── Warning/SOS indicator (small triangle) at route midpoint ── -->
    <!-- Triangle outline -->
    <path
        android:pathData="M46,54 L51,44 L56,54 Z"
        android:fillColor="#EF4444"
        android:strokeColor="#111820"
        android:strokeWidth="1.5"/>
    <!-- Exclamation body -->
    <path
        android:pathData="M50,47.5 L51,51.5 L52,47.5 Z"
        android:fillColor="#FFFFFF"/>
    <!-- Exclamation dot -->
    <path
        android:pathData="M51,52.5m-0.8,0a0.8,0.8 0,1 1,1.6 0a0.8,0.8 0,1 1,-1.6 0"
        android:fillColor="#FFFFFF"/>

</vector>
